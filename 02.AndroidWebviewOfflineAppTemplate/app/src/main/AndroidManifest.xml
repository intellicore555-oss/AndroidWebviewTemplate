<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- BIOMETRIA -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    <uses-permission android:name="android.permission.USE_FINGERPRINT"/>

    <!-- FOREGROUND SERVICE (OBRIGATÓRIO PARA APPLOCK) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- MONITORAR USO DE APPS (AppLock) -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"/>

    <!-- (OPCIONAL) OVERLAY FUTURO -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- INTERNET (WebView / site online se precisar) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.androidWebViewOfflineApplication">

        <!-- MAIN APP -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- LOCK SCREEN (BIOMETRIA OVERLAY) -->
        <activity
            android:name=".LockScreenActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/TransparentActivity"/>

        <!-- APP LOCK SERVICE (FOREGROUND) -->
        <service
            android:name=".AppLockService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

    </application>

</manifest>
